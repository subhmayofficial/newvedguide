# ============================================
# DELIVERY INTEGRATIONS
# ============================================
# Interakt (WhatsApp API)
INTERAKT_ENABLED=false
INTERAKT_API_URL=https://api.interakt.ai/v1/public/message/`r`nINTERAKT_TEMPLATE_LIST_API_URL=`r`nINTERAKT_API_KEY=
INTERAKT_TEMPLATE_NAME=order_paid_update
INTERAKT_TEMPLATE_LANGUAGE=en
INTERAKT_COUNTRY_CODE=+91
INTERAKT_AUTO_DELIVERY_ON_PAYMENT=true

# SMTP Email (Nodemailer)
SMTP_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_SUPPORT_LINK=
SMTP_RETRY_COUNT=2
SMTP_AUTO_DELIVERY_ON_PAYMENT=true

