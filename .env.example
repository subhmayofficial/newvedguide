# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# RAZORPAY
# ============================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ============================================
# ANALYTICS
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=

# ============================================
# SITE
# ============================================
NEXT_PUBLIC_SITE_URL=https://vedguide.com
# Digits only, with country code (e.g. 919876543210) — used for consultation WhatsApp CTAs
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ============================================
# DELIVERY INTEGRATIONS
# ============================================
# Interakt (WhatsApp API). Omitted = on when INTERAKT_API_KEY is set. Set INTERAKT_ENABLED=false to force off.
INTERAKT_API_URL=https://api.interakt.ai/v1/public/message/
INTERAKT_TEMPLATE_LIST_API_URL=
# Secret key only (from Developer settings). Do not prefix "Basic " — the app adds it.
INTERAKT_API_KEY=
INTERAKT_TEMPLATE_NAME=order_paid_update
INTERAKT_TEMPLATE_LANGUAGE=en
INTERAKT_COUNTRY_CODE=+91
INTERAKT_AUTO_DELIVERY_ON_PAYMENT=true
# Paid kundli only — template with body {{1}} = name, button URL {{1}} (see migration 013)
INTERAKT_KUNDLI_TEMPLATE_NAME=kundlidelivery_bt
INTERAKT_KUNDLI_TEMPLATE_LANG=hi
# First URL button is usually index 0; set 1 if Interakt shows a different index
INTERAKT_KUNDLI_BUTTON_INDEX=0
# Optional full URL; use {order_number} and/or {order_id}. If unset: NEXT_PUBLIC_SITE_URL + /kundli-report
# INTERAKT_KUNDLI_BUTTON_LINK=https://vedguide.com/kundli-report

# SMTP Email (Nodemailer)
SMTP_EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
EMAIL_FROM=
EMAIL_REPLY_TO=
EMAIL_SUPPORT_LINK=
SMTP_RETRY_COUNT=2
SMTP_AUTO_DELIVERY_ON_PAYMENT=true

# ============================================
# BUNNY.NET (Storage + CDN) — server only
# ============================================
# Storage zone → FTP & API → Password (READ/WRITE — not read-only; not the Account-wide API key).
# Zone name, region, and public CDN base URL are in Admin → Settings (DB).
BUNNY_STORAGE_API_KEY=
# Optional: if Settings → Storage region is blank, force API host (e.g. sg for Singapore / sg.storage.bunnycdn.com).
BUNNY_STORAGE_REGION=

